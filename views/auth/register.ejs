<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container narrow">
    <h1><%= contentTitle %></h1>

    <% if (message) { %>
        <div class="alert"><%= message %></div>
    <% } %>

    <form method="POST" action="/auth/register" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <label>
            <span>Ad</span>
            <input type="text" name="name" value="<%= viewData.name %>" required>
        </label>

        <label>
            <span>Soyad</span>
            <input type="text" name="surname" value="<%= viewData.surname %>" required>
        </label>

        <label>
            <span>Email</span>
            <input type="email" name="email" value="<%= viewData.email %>" required>
        </label>

        <label>
            <span>Şifre</span>
            <input type="password" name="password" required>
        </label>

        <label>
            <span>Rol</span>
            <select name="role">
                <option value="user" <%= viewData.role === 'user' ? 'selected' : '' %>>Normal Kullanıcı</option>
                <option value="chef" <%= viewData.role === 'chef' ? 'selected' : '' %>>Şef</option>
            </select>
        </label>

        <button type="submit">Kayıt Ol</button>
    </form>

    <p class="muted">Zaten hesabın var mı? <a href="/auth/login">Giriş yap</a></p>
</main>

<%- include('../partials/scripts.ejs') %>
