<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container">
    <div class="layout">
        <%- include('../partials/side.ejs') %>

        <section class="content">
            <% if (announcements && announcements.length > 0) { %>
                <div class="anc-banner">
                    <h3>Duyurular</h3>
                    <ul>
                        <% announcements.forEach(function(a) { %>
                            <li>
                                <strong><%= a.title %></strong>
                                <span class="muted small">
                                    · <%= new Date(a.createdAt).toLocaleDateString('tr-TR') %>
                                </span>
                                <div><%= a.exp %></div>
                            </li>
                        <% }); %>
                    </ul>
                    <a href="/announcements" class="muted small">Tüm duyurular →</a>
                </div>
            <% } %>

            <% if (dailyMenu && dailyMenu.length > 0) { %>
                <h1>Günün Menüsü</h1>
                <p class="muted">Her kategoriden bugün için seçilmiş bir tarif.</p>
                <div class="recipe-grid daily">
                    <% dailyMenu.forEach(function(r) { %>
                        <article class="recipe-card">
                            <a href="/recipe/<%= r.slug %>" class="recipe-card-link">
                                <% if (r.image) { %>
                                    <img src="<%= r.image %>" alt="<%= r.title %>">
                                <% } else { %>
                                    <div class="recipe-noimg">Görsel yok</div>
                                <% } %>
                                <div class="recipe-body">
                                    <span class="badge"><%= r.categoryName %></span>
                                    <h3><%= r.title %></h3>
                                    <p><%= r.exp %></p>
                                </div>
                            </a>
                        </article>
                    <% }); %>
                </div>
            <% } %>

            <h1><%= contentTitle %></h1>

            <% if (!data || data.length === 0) { %>
                <p class="muted">Henüz tarif yok.</p>
            <% } else { %>
                <div class="recipe-grid">
                    <% data.forEach(function(r) { %>
                        <article class="recipe-card">
                            <a href="/recipe/<%= r.slug %>" class="recipe-card-link">
                                <% if (r.image) { %>
                                    <img src="<%= r.image %>" alt="<%= r.title %>">
                                <% } else { %>
                                    <div class="recipe-noimg">Görsel yok</div>
                                <% } %>
                                <div class="recipe-body">
                                    <span class="badge"><%= r.categoryName %></span>
                                    <h3><%= r.title %></h3>
                                    <p><%= r.exp %></p>
                                </div>
                            </a>
                        </article>
                    <% }); %>
                </div>
            <% } %>
        </section>
    </div>
</main>

<%- include('../partials/scripts.ejs') %>
