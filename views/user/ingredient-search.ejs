<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container">
    <div class="layout">
        <%- include('../partials/side.ejs') %>

        <section class="content">
            <h1><%= contentTitle %></h1>
            <p class="muted">Seçtiğin malzemelerin <strong>tamamını</strong> içeren tarifler listelenir.</p>

            <form class="form ing-form" method="GET" action="/search/ingredients">
                <div class="ing-grid">
                    <% ingredients.forEach(function(i) { %>
                        <label class="ing-item">
                            <input type="checkbox" name="ing" value="<%= i.ingredientid %>"
                                <%= selected.indexOf(i.ingredientid) >= 0 ? 'checked' : '' %>>
                            <span><%= i.name %></span>
                        </label>
                    <% }); %>
                </div>
                <button type="submit">Tarifleri Getir</button>
            </form>

            <% if (selected.length > 0) { %>
                <% if (!data || data.length === 0) { %>
                    <p class="muted">Eşleşen tarif yok.</p>
                <% } else { %>
                    <h2><%= data.length %> sonuç</h2>
                    <div class="recipe-grid">
                        <% data.forEach(function(r) { %>
                            <article class="recipe-card">
                                <a href="/recipe/<%= r.slug %>" class="recipe-card-link">
                                    <% if (r.image) { %>
                                        <img src="<%= r.image %>" alt="<%= r.title %>">
                                    <% } else { %>
                                        <div class="recipe-noimg">Görsel yok</div>
                                    <% } %>
                                    <div class="recipe-body">
                                        <span class="badge"><%= r.categoryName %></span>
                                        <h3><%= r.title %></h3>
                                        <p><%= r.exp %></p>
                                    </div>
                                </a>
                            </article>
                        <% }); %>
                    </div>
                <% } %>
            <% } %>
        </section>
    </div>
</main>

<%- include('../partials/scripts.ejs') %>
