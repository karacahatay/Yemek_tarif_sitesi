<header class="topbar">
    <div class="topbar-inner">
        <a class="brand" href="/">Tarif Sitesi</a>

        <form class="searchbar" method="GET" action="/search" role="search">
            <input type="text" name="q" placeholder="Tarif adı veya malzeme ara..." value="<%= typeof q !== 'undefined' ? q : '' %>">
            <button type="submit">Ara</button>
            <a href="/search/ingredients" class="btn-ghost">Malzemeye göre</a>
        </form>

        <nav class="topnav">
            <% if (isAuth) { %>
                <span class="hello">Merhaba, <%= fullname %></span>
                <a href="/saved">Kayıtlarım</a>
                <% if (role === "chef" || role === "admin") { %>
                    <a href="/admin">Panel</a>
                <% } %>
                <a href="/auth/signout">Çıkış</a>
            <% } else { %>
                <a href="/auth/login">Giriş</a>
                <a href="/auth/register">Kayıt</a>
            <% } %>
        </nav>
    </div>
</header>
