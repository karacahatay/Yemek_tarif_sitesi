<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container">
    <div class="layout">
        <%- include('./admin-side.ejs') %>

        <section class="content">
            <h1><%= contentTitle %></h1>

            <form method="POST" action="/admin/announcements" class="form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <label>
                    <span>Başlık</span>
                    <input type="text" name="title" value="<%= viewData.title %>" required maxlength="200">
                </label>

                <label>
                    <span>İçerik</span>
                    <textarea name="exp" rows="5" required><%= viewData.exp %></textarea>
                </label>

                <label class="inline">
                    <input type="checkbox" name="isactive" <%= viewData.isactive ? 'checked' : '' %>>
                    <span>Aktif (yayında)</span>
                </label>

                <button type="submit">Duyuruyu Yayınla</button>
            </form>
        </section>
    </div>
</main>

<%- include('../partials/scripts.ejs') %>
