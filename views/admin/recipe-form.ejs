<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container">
    <div class="layout">
        <%- include('./admin-side.ejs') %>

        <section class="content">
            <h1><%= contentTitle %></h1>

            <% if (message) { %>
                <div class="alert"><%= message %></div>
            <% } %>

            <!--
                multer multipart/form-data parse eder. csurf body'i göremediği için
                token query'e konur (?_csrf=...). multer'dan SONRA csurf zaten çalıştı,
                ama csurf değeri arar; query'den okur.
            -->
            <form method="POST"
                  action="/admin/recipes?_csrf=<%= encodeURIComponent(csrfToken) %>"
                  enctype="multipart/form-data"
                  class="form">

                <label>
                    <span>Başlık</span>
                    <input type="text" name="title" value="<%= viewData.title %>" required maxlength="200">
                </label>

                <label>
                    <span>Kısa açıklama</span>
                    <textarea name="exp" rows="2" required><%= viewData.exp %></textarea>
                </label>

                <label>
                    <span>Yapılışı</span>
                    <textarea name="instructions" rows="6" required><%= viewData.instructions %></textarea>
                </label>

                <label>
                    <span>Kategori</span>
                    <select name="categoryid" required>
                        <option value="">— Kategori seç —</option>
                        <% categories.forEach(function(c) { %>
                            <option value="<%= c.categoryid %>"
                                <%= viewData.categoryid == c.categoryid ? 'selected' : '' %>>
                                <%= c.name %>
                            </option>
                        <% }); %>
                    </select>
                </label>

                <label>
                    <span>Kapak görseli (opsiyonel, max 5MB)</span>
                    <input type="file" name="image" accept="image/*">
                </label>

                <fieldset class="ing-fieldset">
                    <legend>Malzemeler</legend>
                    <p class="muted small">Kullandığın malzemeleri işaretle, yanına miktar yaz.</p>
                    <div class="ing-form-grid">
                        <% ingredients.forEach(function(i) { %>
                            <div class="ing-row">
                                <label class="ing-item">
                                    <input type="checkbox" name="ing_<%= i.ingredientid %>"
                                        <%= selectedIngredients[i.ingredientid] ? 'checked' : '' %>>
                                    <span><%= i.name %></span>
                                </label>
                                <input type="text"
                                       name="amt_<%= i.ingredientid %>"
                                       placeholder="miktar (örn: 2 yemek kaşığı)"
                                       value="<%= selectedIngredients[i.ingredientid] || '' %>">
                            </div>
                        <% }); %>
                    </div>
                </fieldset>

                <button type="submit">Tarifi Kaydet</button>
            </form>
        </section>
    </div>
</main>

<%- include('../partials/scripts.ejs') %>
