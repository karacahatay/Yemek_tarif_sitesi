<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container">
    <div class="layout">
        <%- include('./admin-side.ejs') %>

        <section class="content">
            <div class="page-head">
                <h1><%= contentTitle %></h1>
                <a href="/admin/recipes/new" class="btn">+ Yeni Tarif</a>
            </div>

            <% if (!data || data.length === 0) { %>
                <p class="muted">Henüz tarif yok.</p>
            <% } else { %>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Görsel</th>
                            <th>Başlık</th>
                            <th>Kategori</th>
                            <% if (role === "admin") { %><th>Şef</th><% } %>
                            <th>Tarih</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% data.forEach(function(r) { %>
                            <tr>
                                <td>
                                    <% if (r.image) { %>
                                        <img src="<%= r.image %>" alt="" class="thumb">
                                    <% } else { %>
                                        <span class="muted small">—</span>
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/recipe/<%= r.slug %>"><%= r.title %></a>
                                </td>
                                <td><%= r.categoryName %></td>
                                <% if (role === "admin") { %>
                                    <td><%= r.chefName %> <%= r.chefSurname %></td>
                                <% } %>
                                <td class="small muted">
                                    <%= new Date(r.createdAt).toLocaleDateString('tr-TR') %>
                                </td>
                                <td>
                                    <form method="POST"
                                          action="/admin/recipes/<%= r.recipeid %>/delete"
                                          onsubmit="return confirm('Bu tarifi silmek istediğine emin misin?');">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="btn-danger">Sil</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </section>
    </div>
</main>

<%- include('../partials/scripts.ejs') %>
