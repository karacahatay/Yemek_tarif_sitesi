<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container">
    <div class="layout">
        <%- include('./admin-side.ejs') %>

        <section class="content">
            <h1><%= contentTitle %></h1>

            <form method="POST"
                  action="/admin/gallery?_csrf=<%= encodeURIComponent(csrfToken) %>"
                  enctype="multipart/form-data"
                  class="form">
                <label>
                    <span>Başlık</span>
                    <input type="text" name="title" placeholder="Görsel başlığı" maxlength="200">
                </label>
                <label>
                    <span>Görsel (max 5MB)</span>
                    <input type="file" name="image" accept="image/*" required>
                </label>
                <button type="submit">Yükle</button>
            </form>

            <h2>Galerideki Görseller (<%= data.length %>)</h2>

            <% if (!data || data.length === 0) { %>
                <p class="muted">Henüz görsel yok.</p>
            <% } else { %>
                <div class="gallery-grid">
                    <% data.forEach(function(g) { %>
                        <div class="gallery-item">
                            <img src="<%= g.image %>" alt="<%= g.title %>">
                            <div class="gallery-body">
                                <div class="gallery-title"><%= g.title %></div>
                                <div class="small muted">
                                    <%= g.userName %> <%= g.userSurname %> ·
                                    <%= new Date(g.createdAt).toLocaleDateString('tr-TR') %>
                                </div>
                                <form method="POST" action="/admin/gallery/<%= g.galleryid %>/delete"
                                      onsubmit="return confirm('Bu görseli sil?');">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="btn-danger">Sil</button>
                                </form>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </section>
    </div>
</main>

<%- include('../partials/scripts.ejs') %>
