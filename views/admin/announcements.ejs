<%- include('../partials/header.ejs') %>
<%- include('../partials/topmenu.ejs') %>

<main class="container">
    <div class="layout">
        <%- include('./admin-side.ejs') %>

        <section class="content">
            <div class="page-head">
                <h1><%= contentTitle %></h1>
                <a href="/admin/announcements/new" class="btn">+ Yeni Duyuru</a>
            </div>

            <% if (!data || data.length === 0) { %>
                <p class="muted">Henüz duyuru yok.</p>
            <% } else { %>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Durum</th>
                            <th>Başlık</th>
                            <th>İçerik</th>
                            <th>Ekleyen</th>
                            <th>Tarih</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% data.forEach(function(a) { %>
                            <tr>
                                <td>
                                    <% if (a.isactive) { %>
                                        <span class="badge active">Aktif</span>
                                    <% } else { %>
                                        <span class="badge passive">Pasif</span>
                                    <% } %>
                                </td>
                                <td><strong><%= a.title %></strong></td>
                                <td class="anc-exp"><%= a.exp %></td>
                                <td><%= a.userName %> <%= a.userSurname %></td>
                                <td class="small muted">
                                    <%= new Date(a.createdAt).toLocaleDateString('tr-TR') %>
                                </td>
                                <td class="row-actions">
                                    <form method="POST" action="/admin/announcements/<%= a.noticeid %>/toggle">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="btn-ghost-sm">
                                            <%= a.isactive ? 'Pasifleştir' : 'Aktifleştir' %>
                                        </button>
                                    </form>
                                    <form method="POST" action="/admin/announcements/<%= a.noticeid %>/delete"
                                          onsubmit="return confirm('Bu duyuruyu sil?');">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="btn-danger">Sil</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </section>
    </div>
</main>

<%- include('../partials/scripts.ejs') %>
